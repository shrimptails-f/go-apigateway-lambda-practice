{
    "name": "Go ApiGateway Lambda Practice DevContainer",
    "dockerComposeFile": "docker-compose.yml",
    "service": "go",
    "workspaceFolder": "/home/dev/backend",
    "postCreateCommand": "task setup",
    "customizations": {
        "vscode": {
            "extensions": [
                "streetsidesoftware.code-spell-checker-cspell-bundled-dictionaries", // スペルチェック
                "ms-azuretools.vscode-docker", // VsCodeでのIntelliSenseやタブ補完用
                "golang.go" // Go言語の拡張機能
            ]
        }
    }
}